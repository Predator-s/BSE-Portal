# ─────────────────────────────────────────────────────────────
# BSE Portal — environment reference (copy per-workspace as needed)
# ─────────────────────────────────────────────────────────────

# Part A — Mock BSE API
MOCK_BSE_PORT=4001
# Default per-pull delay in ms. Lower while developing; the design must
# survive MOCK_BSE_DELAY_MS=600000 (10 minutes). Overridable per request via ?delayMs=
MOCK_BSE_DELAY_MS=1500
# Probability [0..1] that a paginated pull dies partway (mid-pull failure)
MOCK_BSE_FAILURE_RATE=0.2
# Rows returned per page for clients/trades
MOCK_BSE_PAGE_SIZE=200
# Deterministic seed volumes
MOCK_BSE_CLIENTS=400
MOCK_BSE_TRADES=6000
MOCK_BSE_EMPLOYEES=20

# Part B — Portal server
PORT=4002
DATABASE_URL="postgresql://bse:bse@localhost:5433/bse_portal?schema=public"
MOCK_BSE_BASE_URL=http://localhost:4001
# Sync worker
SYNC_INTERVAL_MS=30000
# Per-HTTP-request timeout when talking to BSE (mirrors the "network kills after 30s" rule)
BSE_HTTP_TIMEOUT_MS=30000
JWT_SECRET=dev-only-change-me

# Part B — web (Vite dev)
# REST is proxied to the server via /api. The live-updates WebSocket connects
# DIRECTLY to the server (proxying it through Vite causes noisy EPIPE logs).
# Override only if the server isn't on localhost:4002:
VITE_WS_URL=ws://localhost:4002
